{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "components/*"
      ],
      "@util/*": [
        "util/*"
      ]
    },
    "plugins": [
      {
        "name": "typescript-xwind-plugin",
        "config": ".../User/.../tailwind.config.js",
        //Absolute filepath to tailwind config
        "ignoreErrors": null,
        //regex pattern string or null
        "tags": [
          "tw",
          "xw"
        ]
        //tags that trigger xwind plugin
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
